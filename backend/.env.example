SECRET_KEY=your-secret-key-here
DEBUG=True

# PostgreSQL
DB_NAME=iaas_db
DB_USER=iaas_user
DB_PASSWORD=iaas_pass
DB_HOST=localhost
DB_PORT=5432

# Proxmox — подключение
PROXMOX_HOST=192.168.1.10
PROXMOX_USER=root@pam
PROXMOX_PASSWORD=your-proxmox-password
PROXMOX_VERIFY_SSL=False

# Proxmox — API Token (если задан — используется вместо пароля)
# Создайте токен: Datacenter → Permissions → API Tokens
PROXMOX_TOKEN_NAME=
PROXMOX_TOKEN_VALUE=

# Proxmox — шаблон и сеть
PROXMOX_TEMPLATE_VMID=9000
PROXMOX_DEFAULT_NODE=
PROXMOX_DEFAULT_STORAGE=local-lvm
PROXMOX_DEFAULT_BRIDGE=vmbr0

# Proxmox — пул IP для cloud-init
PROXMOX_IP_POOL_START=192.168.100.10
PROXMOX_IP_POOL_CIDR=24
PROXMOX_IP_GATEWAY=192.168.100.1
PROXMOX_POLL_INTERVAL=5

# DeepSeek AI Assistant
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# AI_ASSISTANT_SYSTEM_PROMPT=Custom system prompt here
